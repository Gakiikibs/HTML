<!DOCTYPE html>

<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Positioning in CSS</title>
<style>
h2{
    background-color: aliceblue;
}
div{
    border: 3px solid black;
    right: 30px;
}
.absolute{

    position:absolute;
    left:50px;
    border: 3px solid blue;

}
.relative{

    position:relative;
    left:100px;
    border: 3px solid red;

}
</style>

</head>

<body>
    <h2>Positioning</h2>
    <div>
        Div with no positioning property
    </div>
    <div class="sticky">
    div with sticky position property
    </div>

    <div class="absolute">
        div with absolute position property
    </div>
<div class="relative">
div with relative position property
</div>
<div class="fixed">
    div with fixed position property
    <h2>Handwriting:Voluta script pro regular
        Handwriting-color:blue
    </h2>
</div>

</body>

</html>